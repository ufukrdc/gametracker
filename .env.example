# --- Bu dosya yalnızca REFERANSTIR ---
# composer create-project ile oluşan gerçek .env dosyanda
# aşağıdaki satırları bul ve şu şekilde düzenle:

APP_NAME=GameTracker
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Veritabanı (XAMPP varsayılanı)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gametracker
DB_USERNAME=root
DB_PASSWORD=

# RAWG API anahtarı — ücretsiz al: https://rawg.io/apidocs
RAWG_API_KEY=BURAYA_RAWG_ANAHTARINI_YAZ
